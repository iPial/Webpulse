# Supabase (Required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google PageSpeed Insights (Required)
GOOGLE_PSI_API_KEY=your-google-psi-api-key

# Cron Secret (Required) — generate with: openssl rand -hex 32
CRON_SECRET=your-cron-secret

# Upstash QStash (Required)
QSTASH_URL=https://qstash.upstash.io
QSTASH_TOKEN=your-qstash-token
QSTASH_CURRENT_SIGNING_KEY=your-qstash-current-signing-key
QSTASH_NEXT_SIGNING_KEY=your-qstash-next-signing-key

# Upstash Redis (Optional)
UPSTASH_REDIS_REST_URL=your-redis-url
UPSTASH_REDIS_REST_TOKEN=your-redis-token

# Slack (Optional)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/xxx/xxx

# Anthropic AI (Optional)
ANTHROPIC_API_KEY=your-anthropic-api-key

# SMTP2GO Email (Optional)
SMTP2GO_API_KEY=your-smtp2go-api-key
SMTP2GO_SENDER=PageSpeed Monitor <noreply@yourdomain.com>
EMAIL_TO=you@example.com

# Google Sheets (Optional)
GOOGLE_SHEETS_ID=your-google-sheets-id
